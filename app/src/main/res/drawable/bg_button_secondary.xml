<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/token_secondary_pressed" />
            <stroke
                android:width="1dp"
                android:color="@color/token_secondary_border" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/token_secondary_bg" />
            <stroke
                android:width="1dp"
                android:color="@color/token_secondary_border" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
